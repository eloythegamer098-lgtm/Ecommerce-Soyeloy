# ==============================================================================
# NEON STORE - CONFIGURACIÓN GLOBAL (PRODUCCIÓN)
# ==============================================================================

# --- BACKEND ---
NODE_ENV=production
PORT=3000

# Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=ecommerce_db
DB_PORT=3306

# Seguridad
JWT_SECRET=tu_clave_secreta_super_segura_aqui
# Lista separada por comas de origenes permitidos
ALLOWED_ORIGINS=https://tu-tienda.com,http://localhost:5173

# Email (SMTP)
EMAIL_USER=tu_correo@dominio.com
EMAIL_PASS=tu_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465

# --- FRONTEND (VITE) ---
# En producción, si el backend sirve el frontend, estas pueden ser relativas o el dominio final
VITE_API_URL=https://tu-tienda.com
VITE_PUBLIC_URL=https://tu-tienda.com/api/v1
